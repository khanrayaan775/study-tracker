{
  "name": "study-tracker",
  "version": "1.0.0",
  "description": "Study Tracker — books & series progress",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron . --no-sandbox\"",
    "electron:build": "vite build && electron-builder --mac"
  },
  "build": {
    "appId": "com.studytracker.app",
    "productName": "Study Tracker",
    "directories": {
      "buildResources": "build"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dir",
      "icon": "build/icon.png"
    },
    "files": ["dist/**/*", "electron/**/*"]
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "vite": "^5.0.0"
  }
}
